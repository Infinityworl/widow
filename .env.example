# Telegram API (required)
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=1234567890:your_bot_token_here

# MongoDB (required)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=telegram_media_bot

# Admins (your Telegram numeric user ID)
ADMINS=123456789

# Groups where users are allowed to search
# Example: -1001111111111,-1002222222222
USER_GROUP_IDS=-1001111111111

# Movie upload source channels
MOVIE_SOURCE_CHANNELS=-1003333333333

# TV series upload source channels
SERIES_SOURCE_CHANNELS=-1004444444444

# Optional: pretty series info card channel
SERIES_INFO_CHANNEL_ID=-1005555555555

# Optional: bot log channel/group
LOG_CHAT_ID=-1006666666666

# Optional: set manually or leave blank and bot auto-detects it
BOT_USERNAME=your_bot_username

# Metadata / poster APIs
TMDB_API_KEY=your_tmdb_api_key
TMDB_BEARER_TOKEN=
OMDB_API_KEY=your_omdb_api_key

# Search settings
MAX_SEARCH_RESULTS=8
RESULT_PAGE_SIZE=10
